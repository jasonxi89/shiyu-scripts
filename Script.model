		如果尾()
		i = i + 1
	循环尾()
	
	//#不带宠战斗设置 = "2动|人物动作|人物目标"
	如果(#不带宠战斗设置 != "")
		分割文本(#配置信息,#不带宠战斗设置,"|","")
