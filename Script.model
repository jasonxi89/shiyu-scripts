			登出回城()
			等待("1000")
		如果尾()
		//如果人在传送石1
		如果(人物详细信息("35") == "233" && 人物详细信息("36") == "78")
			人物转身("0")
			等待("1000")
		如果尾()
		//如果人在传送石2		
		如果(人物详细信息("35") == "242" && 人物详细信息("36") == "100")
			人物转身("2")
			等待("1000")
		如果尾()
		//如果人在传送石3	
		如果(人物详细信息("35") == "162" && 人物详细信息("36") == "130")
			人物转身("2")
			等待("1000")
		如果尾()
		//如果人在传送石4	
		如果(人物详细信息("35") == "141" && 人物详细信息("36") == "148")
			人物转身("0")
			等待("1000")
		如果尾()
	循环尾()
	等待("1000")
模块结束()


