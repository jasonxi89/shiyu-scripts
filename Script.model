//2.01-使用物品
///////////////////////////////////////////////////////////////////////////////
脚本模块("使用物品")
	finditem = 0
	#寻找物品计数器 = "1"
	循环(#寻找物品计数器 <= 人物详细信息("47")+8)
		如果(物品详细信息(#寻找物品计数器 + "8","1") == #待使用的物品)
			finditem = 1
			跳出循环()
		如果尾()
		#寻找物品计数器 = #寻找物品计数器 + "1"
	循环尾()
	如果(finditem == 1)
		双击物品(#寻找物品计数器)
		等待("2000")
		对话NPC("","7")
		等待("1000")
		finditem = 0
	如果尾()

模块结束()
///////////////////////////////////////////////////////////////////////////////
//	2.01-装备物品
//	||---需要预设变量 #待装备的物品=洗礼的想练|火龙盾。。。天空之枪|光之鞋
//	||---摘下物品 #待装备的物品=头部空|手部空|身体空|脚部空|饰品空
///////////////////////////////////////////////////////////////////////////////
脚本模块("装备物品")
	分割文本(#装备列表,#待装备的物品,"|","")
	i = 1
	循环(i <= 取成员数(#装备列表) && #装备列表.i != "")
		如果(#装备列表.i == "头部空"||#装备列表.i == "手部空"||#装备列表.i == "身体空"||#装备列表.i == "脚部空"||#装备列表.i == "饰品空")
			k = 9
			如果(人物详细信息("33") == 人物详细信息("47"))
				游戏黄字提示("物品栏已满,无法摘下身上装备!")
			如果尾()
			循环(k<=人物详细信息("47")+8 && 人物详细信息("33") != 人物详细信息("47"))
				如果(物品详细信息(k,"1") == "")
					如果(#装备列表.i == "头部空" && 物品详细信息("1","1") != "")
						移动物品(1,k)
						循环(物品详细信息("1","1")!="")
							等待("100")
						循环尾()
					如果尾()
					如果(#装备列表.i == "身体空" && 物品详细信息("2","1") != "")
						移动物品(2,k)
						循环(物品详细信息("2","1")!="")
							等待("100")
						循环尾()
					如果尾()		
					如果(#装备列表.i == "脚部空" && 物品详细信息("5","1") != "")
						移动物品(5,k)
						循环(物品详细信息("5","1")!="")
							等待("100")
						循环尾()
					如果尾()			
					如果(#装备列表.i == "手部空" && 物品详细信息("3","1") != "")
						移动物品(3,k)
						循环(物品详细信息("3","1")!="")
							等待("100")
						循环尾()
						如果(物品详细信息("4","1") != "")
							到循环尾()
						如果尾()
					如果尾()	
					如果(#装备列表.i == "手部空" && 物品详细信息("4","1") != "")
						移动物品(4,k)
						循环(物品详细信息("4","1")!="")
							等待("100")
						循环尾()
					如果尾()						
					如果(#装备列表.i == "饰品空" && 物品详细信息("6","1") != "")
						移动物品(6,k)
						循环(物品详细信息("6","1")!="")
							等待("100")
						循环尾()
						如果(物品详细信息("7","1") != "")
							到循环尾()
						如果尾()
					如果尾()	
					如果(#装备列表.i == "饰品空" && 物品详细信息("7","1") != "")
						移动物品(7,k)
						循环(物品详细信息("7","1")!="")
							等待("100")
						循环尾()
					如果尾()						
				如果尾()
				k = k + 1
			循环尾()
		如果尾()
		如果(获取物品数量(#装备列表.i,"") > 0)
			j = 9
			循环(j-8<=人物详细信息("47"))
				如果(物品详细信息(j,"1") == #装备列表.i)
					如果(物品详细信息(j,7)/物品详细信息(j,8) < 0.5)
						游戏黄字提示("【"$#装备列表.i$"】当前耐久为【"$物品详细信息(j,7)$"】，不足50%，请注意！)
						鸣叫()
					如果尾()
					#计数器 = 1
					#物品合集 = ""
					循环(#计数器 <= 8)
						#物品合集 = #物品合集$物品详细信息(#计数器,"1")
						#计数器 = #计数器 + 1
					循环尾()
					如果(寻找文本(#物品合集,#装备列表.i,"","") < 1)
						双击物品(j-8)
						循环(""=="")
							#计数器 = 1
							#物品合集temp = ""
							循环(#计数器 <= 8)
								#物品合集temp = #物品合集temp$物品详细信息(#计数器,"1")
								#计数器 = #计数器 + 1
							循环尾()	
							如果(#物品合集temp != #物品合集)
								跳出循环()
							如果尾()
							等待("100")
						循环尾()
						j = 90
					如果尾()
				如果尾()
				j = j + 1
			循环尾()
		如果尾()
		i = i + 1
	循环尾()
模块结束()
///////////////////////////////////////////////////////////////////////////////
//2.02-装备盘点
///////////////////////////////////////////////////////////////////////////////
脚本模块("装备盘点")
	定义数组 (#返回数列,"30")
	#计数器 = "1"
	#帽子数量 = "0"
	#衣服数量 = "0"
	#鞋子数量 = "0"
	#盾牌数量 = "0"
	#防具套数 = "0"
	循环(#计数器 < "21")
		#物品栏位置 = #计数器 + "8"
		如果(物品详细信息(#物品栏位置,"5") =="帽子"||物品详细信息(#物品栏位置,"5") =="头盔"）
			#帽子位置 = "1" + #帽子数量
			#返回数列.#帽子位置 = #计数器 + "8"
			#帽子数量 = #帽子数量 + "1"
		如果尾()	
		
		如果(物品详细信息(#物品栏位置,"5") =="铠"||物品详细信息(#物品栏位置,"5") =="衣服"||物品详细信息(#物品栏位置,"5") =="长袍"）
			#衣服位置 = "6" + #衣服数量
			#返回数列.#衣服位置 = #计数器 + "8"
			#衣服数量 = #衣服数量 + "1"
		如果尾()	

		如果(物品详细信息(#物品栏位置,"5") =="盾"）
			#盾牌位置 = "11" + #盾牌数量
			#返回数列.#盾牌位置 = #计数器 + "8"
			#盾牌数量 = #盾牌数量 + "1"
		如果尾()	

		如果(物品详细信息(#物品栏位置,"5") =="靴"||物品详细信息(#物品栏位置,"5") =="鞋"）
			#鞋子位置 = "16" + #鞋子数量
			#返回数列.#鞋子位置 = #计数器 + "8"
			#鞋子数量 = #鞋子数量 + "1"
		如果尾()				
		#计数器 = #计数器 + "1"
	
	循环尾()
	
	
	如果(#帽子数量<=#鞋子数量&&#帽子数量<=#衣服数量&&#帽子数量<=#盾牌数量)
		#防具套数 = #帽子数量
	如果尾()
	如果(#鞋子数量<=#帽子数量&&#鞋子数量<=#衣服数量&&#鞋子数量<=#盾牌数量)
		#防具套数 = #鞋子数量
	如果尾()
	如果(#衣服数量<=#鞋子数量&&#衣服数量<=#帽子数量&&#衣服数量<=#盾牌数量)
		#防具套数 = #衣服数量
	如果尾()
	如果(#盾牌数量<=#鞋子数量&&#盾牌数量<=#衣服数量&&#盾牌数量<=#帽子数量)
		#防具套数 = #盾牌数量
	如果尾()
	#返回数列.21 = #防具套数

模块结束()

//	2.021-扔耐久不足50的防具
///////////////////////////////////////////////////////////////////////////////
脚本模块("扔耐久不足50的防具")
	如果(#扔防具耐久 == "")
		#扔防具耐久 = 50
	如果尾()
	#计数器 = "1"
	循环(#计数器 < "28")
		如果(物品详细信息(#计数器,"5") =="帽子"||物品详细信息(#计数器,"5") =="头盔" || 物品详细信息(#计数器,"5") =="铠"||物品详细信息(#计数器,"5") =="衣服"||物品详细信息(#计数器,"5") =="长袍" || 物品详细信息(#计数器,"5") =="盾" || 物品详细信息(#计数器,"5") =="靴"||物品详细信息(#计数器,"5") =="鞋")
			如果(物品详细信息(#计数器,"7") < #扔防具耐久)
				移动物品(#计数器,"100")
				等待("500")
			如果尾()
		如果尾()
		#计数器 = #计数器 + 1
	循环尾()
模块结束()

