	//#人血少保护 = "人血少与多少|人物动作|人物技能|技能等级|人物目标|使用物品|宠物技能|宠物目标"
	//#人血少保护 = "100|技能|补血魔法|4级|人物|使用物品|宠物技能|宠物目标"
	如果( #人血少保护 != "" || #人魔少保护 != "" || #宠血少保护 != "" || #宠魔少保护 != "" )
		定义数组(#战斗保护,"4")
		#战斗保护.1 = #人血少保护
		#战斗保护.2 = #人魔少保护
		#战斗保护.3 = #宠血少保护
		#战斗保护.4 = #宠魔少保护
		i = 1
		循环(i <= "4")
			分割文本(#配置信息,#战斗保护.i,"|","")
			如果(#配置信息.1 != "")
				写配置项(#配置文件临时文件名,"选择框","战斗保护选择框"$i,"真")
				写配置项(#配置文件临时文件名,"编辑框","战斗保护编辑框"$i,#配置信息.1)
				如果(i == 1)
					写配置项(#配置文件临时文件名,"编辑框","脚本人血编辑框"$i,#配置信息.1)
				如果尾()
				如果(i == 2)
					写配置项(#配置文件临时文件名,"编辑框","脚本人魔编辑框"$i,#配置信息.1)
				如果尾()				
			如果尾()
			
			如果(#配置信息.2 != "" && #配置信息.2 != "人物动作")
				如果(#配置信息.2 == "攻击")
					#配置信息temp = "攻击<|>0<||>防御<|>0<||>技能<|>0<||>物品<|>0<||>逃跑<|>0<||>0<|>攻击"
				又如(#配置信息.2 == "防御")
					#配置信息temp = "攻击<|>0<||>防御<|>0<||>技能<|>0<||>物品<|>0<||>逃跑<|>0<||>1<|>防御"
				又如(#配置信息.2 == "技能")
					#配置信息temp = "攻击<|>0<||>防御<|>0<||>技能<|>0<||>物品<|>0<||>逃跑<|>0<||>2<|>技能"
				又如(#配置信息.2 == "物品")
					#配置信息temp = "攻击<|>0<||>防御<|>0<||>技能<|>0<||>物品<|>0<||>逃跑<|>0<||>3<|>物品"
				又如(#配置信息.2 == "逃跑")
					#配置信息temp = "攻击<|>0<||>防御<|>0<||>技能<|>0<||>物品<|>0<||>逃跑<|>0<||>4<|>逃跑"
				如果尾()
				写配置项(#配置文件临时文件名,"组合框","保护人物动作"$i,#配置信息temp)
				#配置信息temp = ""
			如果尾()
			
			如果(#配置信息.3 != "" && #配置信息.3 != "人物技能")
				#配置信息temp = #配置信息.3$"<|>0<||>0<|>"$#配置信息.3
				写配置项(#配置文件临时文件名,"组合框","保护人物技能"$i,#配置信息temp)
				#配置信息temp = ""
			如果尾()
			
			如果(#配置信息.4 != ""  && #配置信息.4 != "技能等级")
				//技能等级只输入数字
				#配置信息temp = "1级<|>0<||>2级<|>0<||>3级<|>0<||>4级<|>0<||>5级<|>0<||>6级<|>0<||>7级<|>0<||>8级<|>0<||>9级<|>0<||>10级<|>0<||>"$(#配置信息.4-1)$"级<|>"$#配置信息.4$"级"
				写配置项(#配置文件临时文件名,"组合框","保护技能等级"$i,#配置信息temp)
				#配置信息temp = ""
			如果尾()		
			
			如果(#配置信息.5 != "" && #配置信息.5 != "人物目标")
				如果(#配置信息.5 == "敌人")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>0<|>敌人"
				又如(#配置信息.5 == "随机")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>1<|>随机"
				又如(#配置信息.5 == "前排")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>2<|>前排"
				又如(#配置信息.5 == "后排")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>3<|>后排"
				又如(#配置信息.5 == "人物")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>4<|>人物"
				又如(#配置信息.5 == "宠物")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>5<|>宠物"
				又如(#配置信息.5 == "无动作")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>6<|>无动作"
				又如(#配置信息.5 == "砍牛")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>7<|>砍牛"
				又如(#配置信息.5 == "强力")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>8<|>强力"
				又如(#配置信息.5 == "超强")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>9<|>超强"
				又如(#配置信息.5 == "血最少")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>10<|>血最少"
				如果尾()
				写配置项(#配置文件临时文件名,"组合框","保护人物目标"$i,#配置信息temp)
				#配置信息temp = ""
			如果尾()	

			如果(#配置信息.6 != "" && #配置信息.6 != "使用物品")
				#配置信息temp = #配置信息.6$"<|>0<||>0<|>"$#配置信息.6
				写配置项(#配置文件临时文件名,"组合框","保护使用物品名称"$i,#配置信息temp)
				#配置信息temp = ""
			如果尾()	
			
			如果(#配置信息.7 != "" && #配置信息.7 != "宠物技能")
				#配置信息temp = #配置信息.7$"<|>0<||>0<|>"$#配置信息.7
				写配置项(#配置文件临时文件名,"组合框","保护宠物技能"$i,#配置信息temp)
				#配置信息temp = ""
				写配置项(#配置文件临时文件名,"选择框","战斗保护选择框"$i,"真")
			如果尾()	
			
			如果(#配置信息.8 != "" && #配置信息.8 != "宠物目标")
				如果(#配置信息.8 == "敌人")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>0<|>敌人"
				又如(#配置信息.8 == "随机")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>1<|>随机"
				又如(#配置信息.8 == "前排")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>2<|>前排"
				又如(#配置信息.8 == "后排")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>3<|>后排"
				又如(#配置信息.8 == "人物")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>4<|>人物"
				又如(#配置信息.8 == "宠物")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>5<|>宠物"
				又如(#配置信息.8 == "无动作")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>6<|>无动作"
				又如(#配置信息.8 == "砍牛")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>7<|>砍牛"
				又如(#配置信息.8 == "强力")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>8<|>强力"
				又如(#配置信息.8 == "超强")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>9<|>超强"
				又如(#配置信息.8 == "血最少")
					#配置信息temp = "敌人<|>0<||>随机<|>0<||>前排<|>0<||>后排<|>0<||>人物<|>0<||>宠物<|>0<||>无动作<|>0<||>砍牛<|>0<||>强力<|>0<||>超强<|>0<||>血最少<|>0<||>10<|>血最少"
				如果尾()
				写配置项(#配置文件临时文件名,"组合框","保护宠物目标"$i,#配置信息temp)
				#配置信息temp = ""
				写配置项(#配置文件临时文件名,"选择框","战斗保护选择框"$(i+5),"真")
			如果尾()			
			
			i = i + 1
		循环尾()
	如果尾()
	
	//#单体补血设置/#强力补血设置/#超强补血设置 = "技能等级|判定人数|判定血量百分比"
	如果(#单体补血设置 != "")
		分割文本(#配置信息,#单体补血设置,"|","")
		写配置项(#配置文件临时文件名,"选择框","传教补血选择框1","真")
		写配置项(#配置文件临时文件名,"组合框","传教补血技能1","补血魔法<|>0<||>0<|>补血魔法")
		写配置项(#配置文件临时文件名,"组合框","传教补血技能等级1","1级<|>0<||>2级<|>0<||>3级<|>0<||>4级<|>0<||>5级<|>0<||>6级<|>0<||>7级<|>0<||>8级<|>0<||>9级<|>0<||>10级<|>0<||>"$(#配置信息.1-1)$"级<|>"$#配置信息.1$"级")
		写配置项(#配置文件临时文件名,"编辑框","传教补血单体编辑框",#配置信息.3)
	如果尾()
	
	如果(#强力补血设置 != "")
		分割文本(#配置信息,#强力补血设置,"|","")
		写配置项(#配置文件临时文件名,"选择框","传教补血选择框2","真")
		写配置项(#配置文件临时文件名,"组合框","传教补血技能2","强力补血魔法<|>0<||>0<|>强力补血魔法")
		写配置项(#配置文件临时文件名,"组合框","传教补血技能等级2","1级<|>0<||>2级<|>0<||>3级<|>0<||>4级<|>0<||>5级<|>0<||>6级<|>0<||>7级<|>0<||>8级<|>0<||>9级<|>0<||>10级<|>0<||>"$(#配置信息.1-1)$"级<|>"$#配置信息.1$"级")
		写配置项(#配置文件临时文件名,"编辑框","强力补血个数编辑框",#配置信息.2)
		写配置项(#配置文件临时文件名,"编辑框","强力补血编辑框",#配置信息.3)
	如果尾()	
	
	如果(#超强补血设置 != "")
		分割文本(#配置信息,#超强补血设置,"|","")
		写配置项(#配置文件临时文件名,"选择框","传教补血选择框3","真")
		写配置项(#配置文件临时文件名,"组合框","传教补血技能3","超强补血魔法<|>0<||>0<|>超强补血魔法")
		写配置项(#配置文件临时文件名,"组合框","传教补血技能等级3","1级<|>0<||>2级<|>0<||>3级<|>0<||>4级<|>0<||>5级<|>0<||>6级<|>0<||>7级<|>0<||>8级<|>0<||>9级<|>0<||>10级<|>0<||>"$(#配置信息.1-1)$"级<|>"$#配置信息.1$"级")
		写配置项(#配置文件临时文件名,"编辑框","超强补血个数编辑框",#配置信息.2)
		写配置项(#配置文件临时文件名,"编辑框","超强补血编辑框",#配置信息.3)
	如果尾()	
	
	//#自动气绝 = "技能等级"
	如果(#自动气绝 != "")
		写配置项(#配置文件临时文件名,"选择框","传教补血选择框4","真")
		写配置项(#配置文件临时文件名,"组合框","传教补血技能等级4","1级<|>0<||>2级<|>0<||>3级<|>0<||>4级<|>0<||>5级<|>0<||>6级<|>0<||>7级<|>0<||>8级<|>0<||>9级<|>0<||>10级<|>0<||>"$(#自动气绝-1)$"级<|>"$#自动气绝$"级")
		写配置项(#配置文件临时文件名,"组合框","传教补血技能4","气绝回复<|>0<||>0<|>气绝回复")
	如果尾()
	
	//#自动扔血 = "判定血量百分比|使用物品"
	如果(#自动扔血 != "")
		分割文本(#配置信息,#自动扔血,"|","")
		写配置项(#配置文件临时文件名,"选择框","传教补血选择框1","真")	
		写配置项(#配置文件临时文件名,"选择框","队长丢补血选择框","真")	
		写配置项(#配置文件临时文件名,"编辑框","传教补血单体编辑框",#配置信息.1)
		写配置项(#配置文件临时文件名,"组合框","丢血选择框",#配置信息.2$"<|>0<||>0<|>"$#配置信息.2)
		#配置信息 = ""
	如果尾()
	
	//#自动使用恢复魔法设置 = "每6回合|恢复魔法|2级"
	如果(#自动使用恢复魔法设置 != "")
		分割文本(#配置信息,#自动使用恢复魔法设置,"|","")
		写配置项(#配置文件临时文件名,"组合框","组合框_首回合","首回合<|>0<||>每6回合<|>0<||>1<|>"$#配置信息.1)
		如果(#配置信息.2 == "恢复魔法")
			序号 = 0
		又如(#配置信息.2 == "强力恢复魔法")
			序号 = 1
		又如(#配置信息.2 == "超强恢复魔法")
			序号 = 2
		如果尾()
		写配置项(#配置文件临时文件名,"组合框","传教补血技能5","恢复魔法<|>0<||>强力恢复魔法<|>0<||>超强恢复魔法<|>0<||>"$序号$"<|>"$#配置信息.2)
		如果(取文本左边 (#配置信息.3,2) == 10)
			numlv = 9
		否则()
			numlv = 取文本左边 (#配置信息.3,1) - 1
		如果尾()
		写配置项(#配置文件临时文件名,"组合框","传教补血技能等级5","1级<|>0<||>2级<|>0<||>3级<|>0<||>4级<|>0<||>5级<|>0<||>6级<|>0<||>7级<|>0<||>8级<|>0<||>9级<|>0<||>10级<|>0<||>"$numlv$"<|>"$#配置信息.3)
	如果尾()
	
	//#自动使用恢复魔法敌人名字 = ""
	如果(#自动使用恢复魔法敌人名字 != "")
		写配置项(#配置文件临时文件名,"编辑框","编辑框_每6回合敌人",#自动使用恢复魔法敌人名字)
	如果尾()
	
	//#开启自动恢复指定名字 = "是"
	如果(#开启自动恢复指定名字 == "是")
		写配置项(#配置文件临时文件名,"选择框","传教补血选择框5","真")
	否则()
		写配置项(#配置文件临时文件名,"选择框","传教补血选择框5","假")
	如果尾()

	//#开启自动恢复任何人 = "是"
	如果(#开启自动恢复任何人 == "是")
		写配置项(#配置文件临时文件名,"选择框","选择框_每6回合任何敌人","真")
	否则()
		写配置项(#配置文件临时文件名,"选择框","选择框_每6回合任何敌人","假")
	如果尾()	
	
	//#战斗无延时 = "是/否"
	如果(#战斗无延时 != "")
		如果(#战斗无延时 == "是")
			写配置项(#配置文件临时文件名,"选择框","选择框_战斗无延时","真")	
		否则()
			写配置项(#配置文件临时文件名,"选择框","选择框_战斗无延时","假")	
		如果尾()		
	如果尾()
	
	//#全同第一栏 = "是/否"
	如果(#全同第一栏 != "")
		如果(#全同第一栏 == "是")
			写配置项(#配置文件临时文件名,"选择框","选择框_同一设置","真")	
		否则()
			写配置项(#配置文件临时文件名,"选择框","选择框_同一设置","假")	
		如果尾()
	如果尾()
	
	//#高速切图 = "是/否"
	如果(#高速切图 != "")
		如果(#高速切图 == "是")
			写配置项(#配置文件临时文件名,"选择框","选择框_高速切图","真")	
		否则()
			写配置项(#配置文件临时文件名,"选择框","选择框_高速切图","假")	
		如果尾()
	如果尾()	
	
	//#特殊回合 = "开/关"
	如果(#特殊回合 != "")
		如果(#特殊回合 == "开")
			写配置项(#配置文件临时文件名,"选择框","选择框_启动回合","真")	
		如果尾()
		如果(#特殊回合 != "开")
			写配置项(#配置文件临时文件名,"选择框","选择框_启动回合","假")	
		如果尾()
	如果尾()		
	
	//#人血少于使用物品/#人魔少于使用物品/#宠血少于使用物品/#宠魔少于使用物品/#卡时少于使用物品 = "判定百分比|使用物品"
	如果(#人血少于使用物品 != "" || #人魔少于使用物品 != "" || #宠血少于使用物品 != "" || #宠魔少于使用物品 != "" || #卡时少于使用物品 != "" )
		定义数组(#使用物品,"5")
		#使用物品.1 = #人血少于使用物品
		#使用物品.2 = #人魔少于使用物品
		#使用物品.3 = #宠血少于使用物品
		#使用物品.4 = #宠魔少于使用物品
		#使用物品.5 = #卡时少于使用物品
		i = 1
		循环(i <= "5")
			如果(#使用物品.i != "")
				分割文本(#配置信息,#使用物品.i,"|","")
				写配置项(#配置文件临时文件名,"选择框","非战斗保护选择框"$i,"真")
				写配置项(#配置文件临时文件名,"编辑框","非战斗保护编辑框"$i,#配置信息.1)
				写配置项(#配置文件临时文件名,"组合框","非战斗保护物品名称组合框"$i,#配置信息.2$"<|>0<||>0<|>"$#配置信息.2)
			如果尾()
			i = i + 1
		循环尾()
	如果尾()
	
	//#受伤保护 = "受伤程度|处置方式" 受伤程度 = 白/黄/紫/红 处置方式 = 关闭游戏/停止自动/声音提示/重置脚本/暂停脚本
	如果(#受伤保护 != "")
		分割文本(#配置信息,#受伤保护,"|","")
		如果(#配置信息.1 != "")
			如果(#配置信息.1 == "白")
				写配置项(#配置文件临时文件名,"组合框","受伤组合框","<|>0<||>白<|>0<||>黄<|>0<||>紫<|>0<||>红<|>0<||>1<|>白")
			如果尾()
			如果(#配置信息.1 == "黄")
				写配置项(#配置文件临时文件名,"组合框","受伤组合框","<|>0<||>白<|>0<||>黄<|>0<||>紫<|>0<||>红<|>0<||>2<|>黄")
			如果尾()	
			如果(#配置信息.1 == "紫")
				写配置项(#配置文件临时文件名,"组合框","受伤组合框","<|>0<||>白<|>0<||>黄<|>0<||>紫<|>0<||>红<|>0<||>3<|>紫")
			如果尾()
			如果(#配置信息.1 == "红")
				写配置项(#配置文件临时文件名,"组合框","受伤组合框","<|>0<||>白<|>0<||>黄<|>0<||>紫<|>0<||>红<|>0<||>4<|>红")
			如果尾()				
		如果尾()
		如果(#配置信息.2 != "")
			如果(#配置信息.2 == "关闭游戏")
				写配置项(#配置文件临时文件名,"选择框","挂机保护关闭游戏选择框1","真")
			如果尾()
			如果(#配置信息.2 == "停止自动")
				写配置项(#配置文件临时文件名,"选择框","挂机保护停止自动选择框1","真")
			如果尾()
			如果(#配置信息.2 == "声音提示")
				写配置项(#配置文件临时文件名,"选择框","挂机保护声音选择框1","真")
			如果尾()
			如果(#配置信息.2 == "重置脚本")
				写配置项(#配置文件临时文件名,"选择框","挂机保护重置脚本选择框1","真")
			如果尾()
			如果(#配置信息.2 == "暂停脚本")
				写配置项(#配置文件临时文件名,"选择框","挂机保护暂停脚本选择框1","真")
			如果尾()			
		如果尾()
	如果尾()
	
	//#无物品保护 = "物品名称|处置方式"	处置方式 = 关闭游戏/停止自动/声音提示/重置脚本/暂停脚本
	如果(#无物品保护 != "")
		分割文本(#配置信息,#无物品保护,"|","")
		如果(#配置信息.1 != "")
			写配置项(#配置文件临时文件名,"组合框","无物品组合框",#配置信息.1$"<|>0<||>0<|>"$#配置信息.1)
		如果尾()
		如果(#配置信息.2 != "")
			如果(#配置信息.2 == "关闭游戏")
				写配置项(#配置文件临时文件名,"选择框","挂机保护关闭游戏选择框2","真")
			如果尾()
			如果(#配置信息.2 == "停止自动")
				写配置项(#配置文件临时文件名,"选择框","挂机保护停止自动选择框2","真")
			如果尾()
			如果(#配置信息.2 == "声音提示")
				写配置项(#配置文件临时文件名,"选择框","挂机保护声音选择框2","真")
			如果尾()
			如果(#配置信息.2 == "重置脚本")
				写配置项(#配置文件临时文件名,"选择框","挂机保护重置脚本选择框2","真")
			如果尾()
			如果(#配置信息.2 == "暂停脚本")
				写配置项(#配置文件临时文件名,"选择框","挂机保护暂停脚本选择框2","真")
			如果尾()			
		如果尾()
	如果尾()	
	
	//#队伍少人保护 = "人数|处置方式"	处置方式 = 关闭游戏/停止自动/声音提示/重置脚本/暂停脚本
	如果(#队伍少人保护 != "")
		分割文本(#配置信息,#队伍少人保护,"|","")
		如果(#配置信息.1 != "")
			写配置项(#配置文件临时文件名,"编辑框","队伍人数少于编辑框",#配置信息.1)
		如果尾()
		如果(#配置信息.2 != "")
			如果(#配置信息.2 == "关闭游戏")
				写配置项(#配置文件临时文件名,"选择框","挂机保护关闭游戏选择框4","真")
			如果尾()
			如果(#配置信息.2 == "停止自动")
				写配置项(#配置文件临时文件名,"选择框","挂机保护停止自动选择框4","真")
			如果尾()
			如果(#配置信息.2 == "声音提示")
				写配置项(#配置文件临时文件名,"选择框","挂机保护声音选择框4","真")
			如果尾()
			如果(#配置信息.2 == "重置脚本")
				写配置项(#配置文件临时文件名,"选择框","挂机保护重置脚本选择框4","真")
			如果尾()
			如果(#配置信息.2 == "暂停脚本")
				写配置项(#配置文件临时文件名,"选择框","挂机保护暂停脚本选择框4","真")
			如果尾()			
		如果尾()
	如果尾()		
	
	//#治疗设置 = "检测目标|受伤程度|治疗等级"	检测目标 = 人物/人宠/队友/全部	受伤程度 = 白/黄/紫/红
	如果(#治疗设置 != "")
		写配置项(#配置文件临时文件名,"选择框","选择框_自动战斗受伤治疗","真")
		分割文本(#配置信息,#治疗设置,"|","")
		如果(#配置信息.1 != "")
			如果(#配置信息.1 == "人物")
				写配置项(#配置文件临时文件名,"组合框","组合框_受伤检测范围","人物<|>0<||>人宠<|>0<||>队友<|>0<||>全部<|>0<||>0<|>人物")
			如果尾()
			如果(#配置信息.1 == "人宠")
				写配置项(#配置文件临时文件名,"组合框","组合框_受伤检测范围","人物<|>0<||>人宠<|>0<||>队友<|>0<||>全部<|>0<||>1<|>人宠")
			如果尾()
			如果(#配置信息.1 == "队友")
				写配置项(#配置文件临时文件名,"组合框","组合框_受伤检测范围","人物<|>0<||>人宠<|>0<||>队友<|>0<||>全部<|>0<||>2<|>队友")
			如果尾()
			如果(#配置信息.1 == "全部")
				写配置项(#配置文件临时文件名,"组合框","组合框_受伤检测范围","人物<|>0<||>人宠<|>0<||>队友<|>0<||>全部<|>0<||>3<|>全部")
			如果尾()
		如果尾()
		如果(#配置信息.2 != "")
			如果(#配置信息.2 == "白")
				写配置项(#配置文件临时文件名,"组合框","组合框_自动战斗受伤","<|>0<||>白<|>0<||>黄<|>0<||>紫<|>0<||>红<|>0<||>1<|>白")
			如果尾()
			如果(#配置信息.2 == "黄")
				写配置项(#配置文件临时文件名,"组合框","组合框_自动战斗受伤","<|>0<||>白<|>0<||>黄<|>0<||>紫<|>0<||>红<|>0<||>2<|>黄")
			如果尾()	
			如果(#配置信息.2 == "紫")
				写配置项(#配置文件临时文件名,"组合框","组合框_自动战斗受伤","<|>0<||>白<|>0<||>黄<|>0<||>紫<|>0<||>红<|>0<||>3<|>紫")
			如果尾()
			如果(#配置信息.2 == "红")
				写配置项(#配置文件临时文件名,"组合框","组合框_自动战斗受伤","<|>0<||>白<|>0<||>黄<|>0<||>紫<|>0<||>红<|>0<||>4<|>红")
			如果尾()				
		如果尾()		
		如果(#配置信息.3 != "")
			写配置项(#配置文件临时文件名,"编辑框","编辑框_自动战斗治疗技能等级",#配置信息.3)
		如果尾()	
	如果尾()
	
	//#急救设置 = "检测百分比|技能等级|是否急救队友|是否急救宠物|是否急救队员"
	如果(#急救设置 != "")
		分割文本(#配置信息,#急救设置,"|","")
		写配置项(#配置文件临时文件名,"选择框","选择框_急救","真")
		如果(#配置信息.1 != "")
			写配置项(#配置文件临时文件名,"编辑框","编辑框_急救生命比",#配置信息.1)
		如果尾()
		如果(#配置信息.2 != "")
			写配置项(#配置文件临时文件名,"编辑框","编辑框_急救等级",#配置信息.2)
		如果尾()	
		如果(#配置信息.3 == "是")
			写配置项(#配置文件临时文件名,"选择框","选择框_急救队友","真")
		如果尾()
		如果(#配置信息.4 == "是")
			写配置项(#配置文件临时文件名,"选择框","选择框_急救宠物","真")
		如果尾()
		如果(#配置信息.5 == "是")
			写配置项(#配置文件临时文件名,"选择框","选择框_急救人物","真")
		如果尾()
	如果尾()
	
	//#超时重启 = "开/关"
	//#超时时长 = 时长
	如果(#超时重启 != "")
		如果(#超时时长 == "")
			#超时时长 = 600
		如果尾()
		如果(#超时重启 == "关")
			写配置项(#配置文件临时文件名,"选择框","挂机脚本保护选择框","假")
		如果尾()
		如果(#超时重启 == "开")
			写配置项(#配置文件临时文件名,"组合框","挂机脚本保护组合框","关闭游戏<|>0<||>声音报警<|>0<||>重置脚本<|>0<||>执行标签<|>0<||>2<|>重置脚本")
			写配置项(#配置文件临时文件名,"编辑框","挂机脚本保护时间编辑框",#超时时长)
			写配置项(#配置文件临时文件名,"选择框","挂机脚本保护选择框","真")
		如果尾()		
	如果尾()
	
	//#扔物设置 = "哥布林的卡片|番茄"
	如果(#扔物设置 != "")
		
		写配置项(#配置文件临时文件名,"选择框","自动扔物品选择框","真")
		分割文本(#配置信息,#扔物设置,"|","")
		i = 1
		#写入列表 = ""
		循环(i <= 取成员数(#配置信息))
			如果(i == 1)
				#写入列表 = #配置信息.i$"|0"
			否则()
				#写入列表 = #写入列表$"><br><"$#配置信息.i$"|0"
			如果尾()
			i = i + 1
		循环尾()
		写配置项(#配置文件临时文件名,"编辑框","自动扔物品编辑框全",#写入列表)
	如果尾()
	
	//#扔物开关 = "开/关"
	如果(#扔物开关 == "开")
		写配置项(#配置文件临时文件名,"选择框","自动扔物品选择框","真")
	如果尾()
	如果(#扔物开关 == "关")
		写配置项(#配置文件临时文件名,"选择框","自动扔物品选择框","假")
	如果尾()	
	
	//#贩卖设置 = "哥布林的卡片|番茄"
	如果(#贩卖设置 != "")
		分割文本(#配置信息,#贩卖设置,"|","")
		i = 1
		#写入列表 = ""
		循环(i <= 取成员数(#配置信息))
			如果(i == 1)
				#写入列表 = #配置信息.i$",1"
			否则()
				#写入列表 = #写入列表$"><br><"$#配置信息.i$",1"
			如果尾()
			i = i + 1
		循环尾()
		写配置项(#配置文件临时文件名,"编辑框","自动贩卖物品编辑框全",#写入列表)
	如果尾()
	
	//#自动贩卖 = "开/关"
	如果(#自动贩卖 == "开")
		写配置项(#配置文件临时文件名,"选择框","自动贩卖列表选择框","真")
	如果尾()
	如果(#自动贩卖 == "关")
		写配置项(#配置文件临时文件名,"选择框","自动贩卖列表选择框","假")
	如果尾()	
	
	//#宠邮配置 = "宠邮物品|宠邮数量|宠邮名字|收件人名字"
	如果(#宠邮配置 != "")
		分割文本(#配置文件,#宠邮配置,"|","")
		如果(#配置文件.1 != "" && #配置文件.2 != "")
			写配置项(#配置文件临时文件名,"编辑框","宠邮编辑框",#配置文件.1$","$#配置文件.2)
		如果尾()
		如果(#配置文件.3 != "")
			写配置项(#配置文件临时文件名,"编辑框","宠邮名编辑框",#配置文件.3)
		如果尾()
		写配置项(#配置文件临时文件名,"组合框","组合框_名片数组","名片的第一个人<|>0<||>-1<|>"$#配置文件.4)
	如果尾()

	//#升级加点 = "体力|力量|强度|速度|魔法|宠物加点(体力/力量/强度/速度/魔法)"
	如果(#升级加点 != "")
		分割文本(#配置信息,#升级加点,"|","")
		如果(#配置信息.1 == "" || #配置文件.1 == 0)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点体力","体力0<|>0<||>体力1<|>0<||>体力2<|>0<||>0<|>体力0")
		如果尾()
		如果(#配置信息.1 == 1)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点体力","体力0<|>0<||>体力1<|>0<||>体力2<|>0<||>1<|>体力1")
		如果尾()		
		如果(#配置信息.1 == 2)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点体力","体力0<|>0<||>体力1<|>0<||>体力2<|>0<||>2<|>体力2")
		如果尾()	
		如果(#配置信息.2 == "" || #配置信息.2 == 0)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点力量","力量0<|>0<||>力量1<|>0<||>力量2<|>0<||>0<|>力量0")
		如果尾()
		如果(#配置信息.2 == 1)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点力量","力量0<|>0<||>力量1<|>0<||>力量2<|>0<||>1<|>力量1")
		如果尾()		
		如果(#配置信息.2 == 2)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点力量","力量0<|>0<||>力量1<|>0<||>力量2<|>0<||>2<|>力量2")
		如果尾()	
		如果(#配置信息.3 == "" || #配置信息.3 == 0)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点强度","强度0<|>0<||>强度1<|>0<||>强度2<|>0<||>0<|>强度0")
		如果尾()
		如果(#配置信息.3 == 1)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点强度","强度0<|>0<||>强度1<|>0<||>强度2<|>0<||>1<|>强度1")
		如果尾()		
		如果(#配置信息.3 == 2)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点强度","强度0<|>0<||>强度1<|>0<||>强度2<|>0<||>2<|>强度2")
		如果尾()	
		如果(#配置信息.4 == "" || #配置信息.4 == 0)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点速度","速度0<|>0<||>速度1<|>0<||>速度2<|>0<||>0<|>速度0")
		如果尾()
		如果(#配置信息.4 == 1)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点速度","速度0<|>0<||>速度1<|>0<||>速度2<|>0<||>1<|>速度1")
		如果尾()		
		如果(#配置信息.4 == 2)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点速度","速度0<|>0<||>速度1<|>0<||>速度2<|>0<||>2<|>速度2")
		如果尾()	
		如果(#配置信息.5 == "" || #配置信息.5 == 0)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点魔法","魔法0<|>0<||>魔法1<|>0<||>魔法2<|>0<||>0<|>魔法0")
		如果尾()
		如果(#配置信息.5 == 1)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点魔法","魔法0<|>0<||>魔法1<|>0<||>魔法2<|>0<||>1<|>魔法1")
		如果尾()		
		如果(#配置信息.5 == 2)
			写配置项(#配置文件临时文件名,"组合框","组合框_加点魔法","魔法0<|>0<||>魔法1<|>0<||>魔法2<|>0<||>2<|>魔法2")
		如果尾()	
		如果(#配置信息.6 == "" || #配置信息.6 == "不加点")
			写配置项(#配置文件临时文件名,"组合框","组合框_加点宠物","不加点<|>0<||>体力<|>0<||>力量<|>0<||>强度<|>0<||>速度<|>0<||>魔法<|>0<||><|>0<||>0<|>不加点")
		如果尾()
		如果(#配置信息.6 == "体力")
			写配置项(#配置文件临时文件名,"组合框","组合框_加点宠物","不加点<|>0<||>体力<|>0<||>力量<|>0<||>强度<|>0<||>速度<|>0<||>魔法<|>0<||><|>0<||>1<|>体力")
		如果尾()
		如果(#配置信息.6 == "力量")
			写配置项(#配置文件临时文件名,"组合框","组合框_加点宠物","不加点<|>0<||>体力<|>0<||>力量<|>0<||>强度<|>0<||>速度<|>0<||>魔法<|>0<||><|>0<||>2<|>力量")
		如果尾()
		如果(#配置信息.6 == "强度")
			写配置项(#配置文件临时文件名,"组合框","组合框_加点宠物","不加点<|>0<||>体力<|>0<||>力量<|>0<||>强度<|>0<||>速度<|>0<||>魔法<|>0<||><|>0<||>3<|>强度")
		如果尾()
		如果(#配置信息.6 == "速度")
			写配置项(#配置文件临时文件名,"组合框","组合框_加点宠物","不加点<|>0<||>体力<|>0<||>力量<|>0<||>强度<|>0<||>速度<|>0<||>魔法<|>0<||><|>0<||>4<|>速度")
		如果尾()
		如果(#配置信息.6 == "魔法")
			写配置项(#配置文件临时文件名,"组合框","组合框_加点宠物","不加点<|>0<||>体力<|>0<||>力量<|>0<||>强度<|>0<||>速度<|>0<||>魔法<|>0<||><|>0<||>5<|>魔法")
		如果尾()
		写配置项(#配置文件临时文件名,"选择框","选择框_升级加点","真")
	如果尾()

	//	5.5.1-#自动采集 = "开/关"	
	//	||--#采集技能 = "狩猎|伐木|挖掘|狩猎体验|伐木体验|挖掘体验"
	如果(#自动采集 == "开")
		如果(#采集技能 == "狩猎")
			写配置项(#配置文件临时文件名,"组合框","组合框_后台高速采集","关闭<|>0<||>狩猎<|>0<||>伐木<|>0<||>挖掘<|>0<||>狩猎体验<|>0<||>伐木体验<|>0<||>挖掘体验<|>0<||><|>0<||>1<|>"$#采集技能)		
		如果尾()
		如果(#采集技能 == "伐木")
			写配置项(#配置文件临时文件名,"组合框","组合框_后台高速采集","关闭<|>0<||>狩猎<|>0<||>伐木<|>0<||>挖掘<|>0<||>狩猎体验<|>0<||>伐木体验<|>0<||>挖掘体验<|>0<||><|>0<||>2<|>"$#采集技能)				
		如果尾()
		如果(#采集技能 == "挖掘")
			写配置项(#配置文件临时文件名,"组合框","组合框_后台高速采集","关闭<|>0<||>狩猎<|>0<||>伐木<|>0<||>挖掘<|>0<||>狩猎体验<|>0<||>伐木体验<|>0<||>挖掘体验<|>0<||><|>0<||>3<|>"$#采集技能)		
		如果尾()
		如果(#采集技能 == "狩猎体验")
			写配置项(#配置文件临时文件名,"组合框","组合框_后台高速采集","关闭<|>0<||>狩猎<|>0<||>伐木<|>0<||>挖掘<|>0<||>狩猎体验<|>0<||>伐木体验<|>0<||>挖掘体验<|>0<||><|>0<||>4<|>"$#采集技能)		
		如果尾()
		如果(#采集技能 == "伐木体验")
			写配置项(#配置文件临时文件名,"组合框","组合框_后台高速采集","关闭<|>0<||>狩猎<|>0<||>伐木<|>0<||>挖掘<|>0<||>狩猎体验<|>0<||>伐木体验<|>0<||>挖掘体验<|>0<||><|>0<||>5<|>"$#采集技能)		
		如果尾()
		如果(#采集技能 == "挖掘体验")
			写配置项(#配置文件临时文件名,"组合框","组合框_后台高速采集","关闭<|>0<||>狩猎<|>0<||>伐木<|>0<||>挖掘<|>0<||>狩猎体验<|>0<||>伐木体验<|>0<||>挖掘体验<|>0<||><|>0<||>6<|>"$#采集技能)		
		如果尾()		
		如果(#采集速度 != "")
			写配置项(#配置文件临时文件名,"编辑框","编辑框_后台采集间隔",#采集速度)	
		如果尾()
	如果尾()
	如果(#自动采集 == "关")
		写配置项(#配置文件临时文件名,"组合框","组合框_后台高速采集","关闭<|>0<||>狩猎<|>0<||>伐木<|>0<||>挖掘<|>0<||>狩猎体验<|>0<||>伐木体验<|>0<||>挖掘体验<|>0<||><|>0<||>0<|>关闭")
	如果尾()	
	
	//自动开启高速功能和高速切图功能
	写配置项(#配置文件临时文件名,"选择框","选择框_高速战斗万能选择框","真")
	写配置项(#配置文件临时文件名,"选择框","选择框_战斗无限等待","真")
	写配置项(#配置文件临时文件名,"选择框","选择框_云迷宫","真")
	写配置项(#配置文件临时文件名,"选择框","选择框_高速移动","真")
	载入设置(人物详细信息("1")$"临时配置文件.ini")

	删除文件(#配置文件临时文件名)
模块结束()
