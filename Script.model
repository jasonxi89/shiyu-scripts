//fox辅助设置
脚本模块("fox辅助设置")
	
	#配置文件临时文件名 = 取工作目录()$"\config\"$人物详细信息("1")$"临时配置文件.ini"
	//#战斗设置 = "人物动作|人物技能|技能等级|人物目标|宠物技能|宠物目标|物品名称"
	i = 1
	定义数组(#战斗设置,"6")
	#战斗设置.1 = #战斗设置1
	#战斗设置.2 = #战斗设置2
	#战斗设置.3 = #战斗设置3
	#战斗设置.4 = #战斗设置4
	#战斗设置.5 = #战斗设置5
	#战斗设置.6 = #战斗设置6
	循环( i <= 6)	
		如果(#战斗设置.i !="")
			分割文本(#配置信息,#战斗设置.i,"|","")
			如果(#配置信息.1 != "" && #配置信息.1 != "人物动作")
				如果(#配置信息.1 == "攻击")
					#配置信息temp = "攻击<|>0<||>防御<|>0<||>技能<|>0<||>物品<|>0<||>逃跑<|>0<||>0<|>攻击"
				又如(#配置信息.1 == "防御")
					#配置信息temp = "攻击<|>0<||>防御<|>0<||>技能<|>0<||>物品<|>0<||>逃跑<|>0<||>1<|>防御"
				又如(#配置信息.1 == "技能")
					#配置信息temp = "攻击<|>0<||>防御<|>0<||>技能<|>0<||>物品<|>0<||>逃跑<|>0<||>2<|>技能"
				又如(#配置信息.1 == "物品")
					#配置信息temp = "攻击<|>0<||>防御<|>0<||>技能<|>0<||>物品<|>0<||>逃跑<|>0<||>3<|>物品"
				又如(#配置信息.1 == "逃跑")
					#配置信息temp = "攻击<|>0<||>防御<|>0<||>技能<|>0<||>物品<|>0<||>逃跑<|>0<||>4<|>逃跑"
				如果尾()
				写配置项(#配置文件临时文件名,"组合框","人物动作"$i,#配置信息temp)
				#配置信息temp = ""
			如果尾()
			如果(#配置信息.2 != "" && #配置信息.2 != "人物技能")
				#配置信息temp = #配置信息.2$"<|>0<||>0<|>"$#配置信息.2
				写配置项(#配置文件临时文件名,"组合框","人物技能"$i,#配置信息temp)
				#配置信息temp = ""
			如果尾()
			如果(#配置信息.3 != "" && #配置信息.3 != "技能等级")
				//技能等级只输入数字
				#配置信息temp = "1级<|>0<||>2级<|>0<||>3级<|>0<||>4级<|>0<||>5级<|>0<||>6级<|>0<||>7级<|>0<||>8级<|>0<||>9级<|>0<||>10级<|>0<||>"$(#配置信息.3-1)$"级<|>"$#配置信息.3$"级"
				写配置项(#配置文件临时文件名,"组合框","技能等级"$i,#配置信息temp)
