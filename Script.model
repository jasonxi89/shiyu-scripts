//1.06-法兰出南门
///////////////////////////////////////////////////////////////////////////////
脚本模块("法兰出南门")
	等待("500")
	调用脚本模块("到中间传送石")
	循环(人物详细信息("34") != "芙蕾雅")
		自动寻路("153","241")
		等待("1500")
	循环尾()
模块结束()
//1.08-法兰到灵堂
///////////////////////////////////////////////////////////////////////////////
脚本模块("法兰到灵堂")

	如果(人物详细信息("34") == "法兰城")
		等待("500")
		调用脚本模块("到中间传送石")
		自动寻路("153","101")
		移动到("153","100")
		循环(人物详细信息("34")!="里谢里雅堡")
			等待("1000")
		循环尾()
	如果尾()
	如果(人物详细信息("34")=="里谢里雅堡")
		自动寻路("47","86")
		移动到("47","85")
		循环(人物详细信息("34")!="召唤之间\\z5")
			等待("1000")
		循环尾()
	如果尾()
	如果(人物详细信息("34")=="召唤之间\\z5")
		自动寻路("27","9")
		移动到("27","8")
		循环(人物详细信息("34")!="回廊\\z5")
			等待("1000")
		循环尾()
	如果尾()	
	如果(人物详细信息("34")=="回廊\\z5")
		自动寻路("23","20")
		移动到("23","19")
		循环(人物详细信息("34")!="灵堂\\z5")
			等待("1000")
		循环尾()
	如果尾()

模块结束()	
//1.09-法兰卖魔石
///////////////////////////////////////////////////////////////////////////////
脚本模块("法兰卖魔石")

	等待("500")
	调用脚本模块("到西边传送石")
	自动寻路("93","78")
	移动到("94","78")
	循环(人物详细信息("34")=="法兰城")
		等待("1000")
	循环尾()
	自动寻路("17","18")
	#NPC坐标 = 获取周围信息("耶莱达美","NPC","","")
	分割文本(#NPC坐标集,#NPC坐标,"|","")
	移动到(#NPC坐标集.2 - "2",#NPC坐标集.3)
	等待("1000")
	出售物品("2")
	等待("2000")

模块结束()
//1.10-法兰买布
///////////////////////////////////////////////////////////////////////////////
脚本模块("法兰买布")

	如果(人物详细信息("34") == "法兰城")
		等待("500")
		调用脚本模块("到中间传送石")
		自动寻路("116","112")
		移动到("117","112")
		循环(人物详细信息("34")!="流行商店\\z0")
			等待("1000")
		循环尾()
	如果尾()
	如果(人物详细信息("34") == "流行商店\\z0")
		自动寻路("7","9")
		#NPC坐标 = 获取周围信息("布商克萝姆","NPC","","")
		分割文本(#NPC坐标集,#NPC坐标,"|","")
		移动到(#NPC坐标集.2,#NPC坐标集.3 + "2")
		等待("1000")
		如果(#购买清单 != "")
			购买物品("0",#购买清单)
			等待("3000")
		如果()
	如果尾()

模块结束()
//1.11-法兰换矿
///////////////////////////////////////////////////////////////////////////////
脚本模块("法兰换矿")

	等待("500")
	调用脚本模块("到西边传送石")
	自动寻路("106","61")
	循环(人物详细信息("34")!="米克尔工房\\z0")
		等待("1000")
	循环尾()

	自动寻路(#换矿X坐标,#换矿Y坐标)
	等待("1500")
	交换物品(#换矿方向,#换矿名称)
	等待("1500")


模块结束()
