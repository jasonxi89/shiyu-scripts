//	2.05-获取声望称号
脚本模块("获取声望称号")
	声望称号列表 = "恶人|受忌讳的人|受挫折的人|无名的旅人|路旁的落叶|水面上的小草|呢喃的歌声|地上的月影|奔跑的春风|苍之风云|摇曳的金星|欢喜的慈雨|蕴含的太阳|敬畏的寂静|无尽星空|迈步前进者|追求技巧的人|刻于新月之铭|掌上的明珠|敬虔的技巧|踏入神的领域|贤者|神匠摘星的技巧|万物创造者|持石之贤者"
	分割文本(声望数组,声望称号列表,"|","")
	i = 1
	循环(i<=取成员数(声望数组))
		如果(人物称号信息(声望数组.i) != -1)
			返回(声望数组.i)
		如果尾()
		i = i + 1
	循环尾()
模块结束()
////////////////////////////////////////////////////////
//	2.06-检测队伍成员等级
脚本模块("检测队伍成员等级")
	起始点 = 2
	队伍人数 = 人物详细信息("37")
	统计 = 0
	循环(起始点<=人物详细信息("37"))
		如果(读配置项(#配置文件地址,队伍信息(起始点,"1"),"等级")>= #检测队伍成员等级)
			统计 = 统计 + 1
		如果尾()
		起始点 = 起始点 + 1
	循环尾()

	如果( 统计>= (人物详细信息("37") -1) )
		返回("是")
	否则()
		返回("否")
	如果尾()
模块结束()
