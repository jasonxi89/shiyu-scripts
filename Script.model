////////////////////////////////////////////////////////////////////////////////////////////////
//		6.01-设置队员任务
//		||---#队员任务 = 参数1|参数2|参数3|...|参数N
//		||---参数1 = 命令，参数2-N为适配1的各种参数用|分割
脚本模块("设置队员任务")
	如果(#队员任务 == "")
		信息提示("未设置队员任务!","","")
	如果尾()
	//检测已登记队员数量
	#队员名称集合 = 读内存变量(#脚本识别ID$人物详细信息("52"))
	分割文本(#队员名称列表,#队员名称集合,"|","")	
	如果(#队伍人数 != "")
		如果(取成员数(#队员名称列表) < #队伍人数 - 1)
			游戏黄字提示("运行脚本队员只有 "$取成员数(#队员名称列表)$" 人，不足5人,等待中...")
		如果尾()
		循环(""=="")
			#队员名称集合 = 读内存变量(#脚本识别ID$人物详细信息("52"))
			分割文本(#队员名称列表,#队员名称集合,"|","")	
			如果(取成员数(#队员名称列表) == #队伍人数 - 1)
				跳出循环()
			如果尾()
			等待("1000")
		循环尾()
	如果尾()
	任务内容 = 人物详细信息("46")$"|"$#队员任务
	计数器 = 1
	循环(计数器 <= #队伍人数 -1)
		写内存变量(#队员名称列表.计数器$"任务",任务内容)
		计数器 = 计数器 + 1
	循环尾()
	#队员任务 = ""
模块结束()
////////////////////////////////////////////////////////////////////////////////////////////////
//6.02-延迟
/////////////////////////////////////////////////////////
脚本模块("延迟")
	#待执行任务 = 读内存变量(人物详细信息("1")$"任务")
	游戏黄字提示(#待执行任务)
	如果(#待执行任务 != "" && 寻找文本(#待执行任务,人物详细信息("46"),"","") > 0)
		分割文本(任务参数,#待执行任务,"|","")
		#待使用的物品 = 任务参数.4
		如果(任务参数.2 == "调用脚本模块")
			调用脚本模块(任务参数.3)
		如果尾()
		写内存变量(人物详细信息("1")$"任务","")
	如果尾()
	#计数器 = 2
	记录信息 = 人物详细信息("1")

	循环(#计数器<= 120)
		如果(#计数器 < 53)
			记录信息 = 记录信息$"|"$人物详细信息(#计数器)
		如果尾()
		如果(#计数器>60 && #计数器 <= 100)
			记录信息 = 记录信息$"|"$物品详细信息(#计数器-52,"1")$"-"$物品详细信息(#计数器-52,"4")
		如果尾()
		如果(#计数器>100)
			记录信息 = 记录信息$"|"$宠物详细信息(当前出战宠物(),#计数器-100)
		如果尾()
		#计数器 = #计数器 + 1
	循环尾()

	如果( #上次记录信息 != 记录信息)
		写内存变量(人物详细信息("1"),记录信息)
		#上次记录信息 = 记录信息
	如果尾()
	等待("1000")
模块结束()
////////////////////////////////////////////////////////



/////
//宠邮发送配置 - 自动查找宠物+写配置项+载入设置
//调用前设置: #宠邮物品名, #宠邮物品数量, #宠邮收件人
//调用后宠物名存在: #宠邮宠物名
脚本模块("宠邮发送配置")
	// 找第一只有名字的宠物
	宠邮设置("1")
	#宠邮宠物名 = ""
	#p = "1"
	循环(#p <= "5")
		如果(宠物详细信息(#p,"1") != "" && #宠邮宠物名 == "")
			#宠邮宠物名 = 宠物详细信息(#p,"1")
		如果尾()
		#p = #p + 1
	循环尾()
	如果(#宠邮宠物名 != "" && #宠邮物品名 != "" && #宠邮收件人 != "")
		#宠邮ini = 取工作目录()$"\config\"$人物详细信息("1")$"宠邮临时.ini"
		写配置项(#宠邮ini,"编辑框","宠邮编辑框",#宠邮物品名$"|"$#宠邮物品数量)
		写配置项(#宠邮ini,"编辑框","宠邮名编辑框",#宠邮宠物名)
		写配置项(#宠邮ini,"组合框","组合框_名片数组","名片的第一个人<|>0<||>-1<|>"$#宠邮收件人)
		载入设置(人物详细信息("1")$"宠邮临时.ini")
	如果尾()
模块结束()
