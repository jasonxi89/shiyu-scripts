		循环(#队伍人数 != "0" && #队伍人数 != "1" && #队伍人数 != "2" && #队伍人数 != "3" && #队伍人数 != "4" && #队伍人数 != "5")
			#队伍人数 = 信息输入("请输入队伍人数","发现问题请反馈给tudou","5")
		循环尾()
		状态控制("9")
		如果(#队伍人数 == "1")
			#队伍人数 = "0"
		如果尾()
		#是否为队长 = "是"
	如果尾()
	如果(#是否为队长 == "6")
		状态控制("2")
		#是否为队长 = "否"
	如果尾()
	
模块结束()

