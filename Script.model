脚本模块("判定脚本模块编号")
	#脚本模块编号 = 20260114
	如果(#现行脚本模块编号 > #脚本模块编号)
		信息提示("脚本模块不符合脚本呢要求，请到群内下载最新版本脚本模块进行替换！","","")
		结束脚本()
	如果尾()
模块结束()

