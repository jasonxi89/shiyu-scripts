/////////////////////////////////////////////////////////
//	2.08-写物品信息
脚本模块("写物品信息")
	i = 9
	循环(i<=48)
		#存档内容 = 读配置项(取工作目录()$"\所有角色的物品.txt",人物详细信息("1"),"人物背包"$(i-8))
		如果(物品详细信息(i,"1") != "" || (物品详细信息(i,"1") == "" && #存档内容 != ""))
			如果(物品详细信息(i,"1") != "")
				如果(物品详细信息(i,"4") == 0)
					当前物品数量 = 1
				否则()
					当前物品数量 = 物品详细信息(i,"4")
				如果尾()
				写配置项(取工作目录()$"\所有角色的物品.txt",人物详细信息("1"),"人物背包"$(i-8),物品详细信息(i,"1")$","$当前物品数量)
			如果尾()
			如果(物品详细信息(i,"1") == "")
				写配置项(取工作目录()$"\所有角色的物品.txt",人物详细信息("1"),"人物背包"$(i-8),物品详细信息(i,"1"))
			如果尾()			
		如果尾()
		i=i+1
	循环尾()
模块结束()
/////////////////////////////////////////////////////////
//	2.09-获取队友物品数量
//	||---返回结果不包含自身物品判定
//	||---模式1为全队都有对应的数量才返回是
//	||---模式2为有1人符合条件即可
//	||---#获取队友物品数量 = "寿喜锅|3|1"
//	||---#待获取物品名称 = "寿喜锅"
//	||---#待获取物品数量 = "3"
//	||---#模式 = "1/2"
//	||---返回 = "是/否"
脚本模块("获取队友物品数量")
	分割文本(#参数列表,#获取队友物品数量,"|","")
	#待获取物品名称 = #参数列表.1
	#待获取物品数量 = #参数列表.2
	#模式 = #参数列表.3
	如果(#模式 == "")
		如果(#参数列表.3 != "" && #参数列表.3 > 0 && #参数列表.3 < 3)
			#模式 = #参数列表.3
		否则()
			#模式 = 1
		如果尾()
	如果尾()	
	符合数量要求计数 = 0
	如果(人物详细信息("37") >= 2)
		当前队友位置 = 2
		循环(当前队友位置 <= 人物详细信息("37"))
			当前队友物品总数量 = 0
			物品位置 = 1
			循环(物品位置 <= 40)
				硬盘存档中指定位置值 = 读配置项(取工作目录()$"\所有角色的物品.txt",队伍信息(当前队友位置,"1"),"人物背包"$物品位置)
				如果(硬盘存档中指定位置值 != "")
					分割文本(硬盘存档中指定位置值列表,硬盘存档中指定位置值,",","")
					如果( 硬盘存档中指定位置值列表.1 == #待获取物品名称)
						当前物品数量 = 硬盘存档中指定位置值列表.2
						如果(当前物品数量 == 0)
							当前物品数量 = 1
						如果尾()
						当前队友物品总数量 = 当前队友物品总数量 + 当前物品数量
					如果尾()
				如果尾()
				物品位置 = 物品位置 + 1
			循环尾()
			如果(当前队友物品总数量 >= #待获取物品数量)
				符合数量要求计数 = 符合数量要求计数 + 1
			如果尾()
			当前队友位置 = 当前队友位置 + 1
		循环尾()
	如果尾()

	如果(#模式 == 1)
		如果(符合数量要求计数 == 人物详细信息("37") - 1 && 人物详细信息("37") > 1)
			返回("是")
		否则()
			返回("否")
		如果尾()
	否则()
		如果(符合数量要求计数 > 0)
			返回("是")
		否则()
			返回("否")
		如果尾()
	如果尾()

/////////////////////////////////////////////////////////
//	2.10-进传送水晶
脚本模块("进传送水晶")
	如果(获取周围信息("临时过图点","NPC","0","0") != "")
		#迷宫坐标 = 获取周围信息("临时过图点","NPC","0","0")
		分割文本(#迷宫坐标列表,#迷宫坐标,"|","")
		游戏黄字提示("传送水晶坐标位于："$#迷宫坐标列表.2$"-"$#迷宫坐标列表.3)
		自动寻路(#迷宫坐标列表.2,#迷宫坐标列表.3)
	如果尾()
模块结束()
////////////////////////////////////////////////////////
//	2.12-队员登记
/////////////////////////////////////////////////////////
脚本模块("队员登记")
	如果(#脚本识别ID != "")
		#队员登录 = 读内存变量(#脚本识别ID$人物详细信息("52"))
		如果(#队员登录 == "")
			写内存变量(#脚本识别ID$人物详细信息("52"),人物详细信息("1"))
		如果尾()
		如果(#队员登录 != "" && 寻找文本(#队员登录,人物详细信息("1"),"","") < 0)
			写入信息 = #队员登录$"|"$人物详细信息("1")
			写内存变量(#脚本识别ID$人物详细信息("52"),写入信息)
		如果尾()
	否则()
		信息提示("未设置脚本识别ID!","","")
	如果尾()
模块结束()
////////////////////////////////////////////////////////
//	2.13-获取队伍最小等级
/////////////////////////////////////////////////////////
脚本模块("获取队伍最小等级")
	#队员名称集合 = 读内存变量(#脚本识别ID$人物详细信息("52"))
	分割文本(#队员名称列表,#队员名称集合,"|","")
	#计数器 = 1
	如果(人物详细信息("16") < 宠物详细信息(当前出战宠物(),"6"))
		#最小等级 = 人物详细信息("16")
	否则()
		#最小等级 = 宠物详细信息(当前出战宠物(),"6")
	如果尾()
	循环(#计数器 <= 取成员数(#队员名称列表))
		#成员信息集合 = 读内存变量(#队员名称列表.#计数器)
		分割文本(#成员信息列表,#成员信息集合,"|","")
		如果(#最小等级 >= #成员信息列表.16)
			#最小等级 = #成员信息列表.16
		如果尾()
		如果(#最小等级 >= #成员信息列表.106)
			#最小等级 = #成员信息列表.16
		如果尾()	
		#计数器 = #计数器 + 1
	循环尾()
	返回(#最小等级)
模块结束()
////////////////////////////////////////////////////////
//	2.14-获取队友物品数量内存
/////////////////////////////////////////////////////////
//	||---#获取队友物品数量 = "寿喜锅|3|1"
//	||---#待获取物品名称 = "寿喜锅"
//	||---#待获取物品数量 = "3"
//	||---#模式 = "1/2" 1为全员有，2为单人有
脚本模块("获取队友物品数量内存")
	分割文本(#参数列表,#获取队友物品数量,"|","")
	#待获取物品名称 = #参数列表.1
	#待获取物品数量 = #参数列表.2
	#模式 = #参数列表.3

	#计数器 = 2
	#符合要求数量 = 0
	循环(#计数器 <= 人物详细信息("37"))
		#成员信息集合 = 读内存变量(队伍信息(#计数器,"1"))
		如果(寻找文本(#成员信息集合,#参数列表.1,"","") > 0)
			分割文本(#成员信息列表,#成员信息集合,"|","")
			#物品计数器 = 53
			#物品总数量 = 0
			循环(#物品计数器 <= 94)
				分割文本(#物品列表,#成员信息列表.#物品计数器,"-","")
				如果(#物品列表.1 == #参数列表.1)
					如果(#物品列表.2 == 0)
						#物品列表.2 = 1
					如果尾()
					#物品总数量 = #物品总数量 + #物品列表.2
				如果尾()
				#物品计数器 = #物品计数器 + 1
			循环尾()
			如果(#物品总数量 >= #参数列表.2)
				#符合要求数量 = #符合要求数量 + 1
			如果尾()
		如果尾()
		#计数器 = #计数器 + 1
	循环尾()

	如果(#参数列表.3 == 2)
		如果(#符合要求数量 > 0)
			返回("是")
		否则()
			返回("否")
		如果尾()
	如果尾()

	如果(#参数列表.3 != 2)
		如果(#符合要求数量 == 人物详细信息("37") - 1)
			返回("是")
		否则()
			返回("否")
		如果尾()
	如果尾()	
模块结束()

////////////////////////////////////////////////////////
//	2.15-队员是否满状态
/////////////////////////////////////////////////////////
脚本模块("是否需要补血魔")
	#队伍名单 = 读内存变量(#脚本识别ID$人物详细信息("52"))
	分割文本(#队伍列表,#队伍名单,"|","")
	如果(取成员数(#队伍列表) < #队伍人数 -1)
		游戏黄字提示("目前登录不足$"#队伍人数"$人,等待队员登录中...")
		循环(""=="")
			#队伍名单 = 读内存变量(#脚本识别ID$人物详细信息("52"))
			分割文本(#队伍列表,#队伍名单,"|","")
			如果(取成员数(#队伍列表) == #队伍人数 -1)
				跳出循环()
			如果尾()
		循环尾()
	如果尾()
	#计数器 = 1
	#状态不满人数 = 0
	#本人状态不满 = 0
	循环(#计数器 < #队伍人数)
		#人物信息 = 读内存变量(#队伍列表.#计数器)
		如果(#人物信息.2 != #人物信息.3 || #人物信息.4 != #人物信息.5 ||#人物信息.102 != #人物信息.103 ||#人物信息.104 != #人物信息.105)
			#状态不满人数 = #状态不满人数 + 1
		如果尾()
		#计数器 = #计数器 + 1
	循环尾()
	如果(人物详细信息("2") < 人物详细信息("3") || 人物详细信息("4") < 人物详细信息("5") || 宠物详细信息(当前出战宠物(),"2") < 宠物详细信息(当前出战宠物(),"3") || 宠物详细信息(当前出战宠物(),"4") < 宠物详细信息(当前出战宠物(),"5"))	
		#本人状态不满 = "是"
	如果尾()	
	如果(#状态不满人数 > 0 || #本人状态不满 == "是")
		返回("是")
	否则()
		返回("否")
	如果尾()
模块结束()
////////////////////////////////////////////////////////
//	2.16-随机NPC集合
//	||---#NPCX = 12
//	||---#NPCY = 13
////////////////////////////////////////////////////////
脚本模块("随机NPC集合")

	
	PX = 人物详细信息("35")
	PY = 人物详细信息("36")
	
	自动寻路(#NPCX - 1,#NPCY)
	
	如果(人物详细信息("35") != PX || 人物详细信息("36") != PY)
		PX = 人物详细信息("35")
		PY = 人物详细信息("36")
		
		自动寻路(#NPCX - 2,#NPCY)
		
		如果(人物详细信息("35") != PX || 人物详细信息("36") != PY)
			自动寻路(#NPCX - 1,#NPCY+1)
			自动寻路(#NPCX - 1,#NPCY)
			自动寻路(#NPCX - 1,#NPCY+1)
			自动寻路(#NPCX - 1,#NPCY)
			返回("是")
		如果尾()
	如果尾()

	自动寻路(#NPCX + 1,#NPCY)
	
	如果(人物详细信息("35") != PX || 人物详细信息("36") != PY)
		PX = 人物详细信息("35")
		PY = 人物详细信息("36")
		
		自动寻路(#NPCX + 2,#NPCY)
		
		如果(人物详细信息("35") != PX || 人物详细信息("36") != PY)
			自动寻路(#NPCX + 1,#NPCY-1)
			自动寻路(#NPCX + 1,#NPCY-1)
			自动寻路(#NPCX + 1,#NPCY-1)
			自动寻路(#NPCX + 1,#NPCY-1)
			返回("是")
		如果尾()
	如果尾()

	自动寻路(#NPCX,#NPCY + 1)
	
	如果(人物详细信息("35") != PX || 人物详细信息("36") != PY)
		PX = 人物详细信息("35")
		PY = 人物详细信息("36")
		
		自动寻路(#NPCX,#NPCY + 1)
		
		如果(人物详细信息("35") != PX || 人物详细信息("36") != PY)
			自动寻路(#NPCX-1,#NPCY + 1)
			自动寻路(#NPCX,#NPCY + 1)
			自动寻路(#NPCX-1,#NPCY + 1)
			自动寻路(#NPCX,#NPCY + 1)
			返回("是")
		如果尾()
	如果尾()
	
	自动寻路(#NPCX,#NPCY - 1)
	
	如果(人物详细信息("35") != PX || 人物详细信息("36") != PY)
		PX = 人物详细信息("35")
		PY = 人物详细信息("36")
		
		自动寻路(#NPCX,#NPCY - 2)
		
		如果(人物详细信息("35") != PX || 人物详细信息("36") != PY)
			自动寻路(#NPCX+1,#NPCY - 1)
			自动寻路(#NPCX,#NPCY - 1)
			自动寻路(#NPCX+1,#NPCY - 1)
			自动寻路(#NPCX,#NPCY - 1)
			
			
			返回("是")
		如果尾()
	如果尾()
	
	返回("否")
模块结束()

////////////////////////////////////////////////////////
//	2.17-获取本角色队伍序号
////////////////////////////////////////////////////////
脚本模块("获取本角色队伍序号")
	
	i = 1
	循环(i <= 5)
		如果(队伍信息(i,1) == 人物详细信息("1"))
			跳出循环()
		如果尾()
		i = i + 1
	循环尾()
	
	返回(i)
模块结束()
////////////////////////////////////////////////////////
//3.02-坐标对话
///////////////////////////////////////////////////////////////////////////////
脚本模块("坐标对话")
	分割文本(XYZ,#对话坐标,"|","")
	如果(#对话坐标 != "")
		X = XYZ.1
		Y = XYZ.2
		X0 = 人物详细信息("35")
		Y0 = 人物详细信息("36")
		如果(X == X0 && Y == Y0 - "1")
			对话NPC("0","7","","","","")
		如果尾()
		如果(X == X0 && Y == Y0 - "2")
			对话NPC("0","7","","","","")
		如果尾()
		如果(X == X0 + "1"&& Y == Y0 - "1")
			对话NPC("1","7","","","","")
		如果尾()
		如果(X == X0 + "1"&& Y == Y0 )
			对话NPC("2","7","","","","")
		如果尾()
		如果(X == X0 + "2" && Y == Y0 )
			对话NPC("2","7","","","","")
		如果尾()
		如果(X == X0 + "1"&& Y == Y0 + "1")
			对话NPC("3","7","","","","")
		如果尾()
		如果(X == X0 && Y == Y0 + "1")
			对话NPC("4","7","","","","")
		如果尾()
		如果(X == X0 && Y == Y0 + "2")
			对话NPC("4","7","","","","")
		如果尾()
		如果(X == X0 - "1"&& Y == Y0 + "1")
			对话NPC("5","7","","","","")
		如果尾()
		如果(X == X0 - "1"&& Y == Y0 )
			对话NPC("6","7","","","","")
		如果尾()	
		如果(X == X0 - "2"&& Y == Y0 )
			对话NPC("6","7","","","","")
		如果尾()	
		如果(X == X0 - "1"&& Y == Y0 - "1")
			对话NPC("7","7","","","","")
		如果尾()
	如果尾()
	
模块结束()

