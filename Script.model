////////////////////////////////////////////////////////////////////
//1.01-到东边传送石
///////////////////////////////////////////////////////////////////
脚本模块("到东边传送石")
//传送石1：233.78.0		传送石2：242.100.2 	传送石3：162.130.2
//传送石4：141.148.0 	传送石5：72.123.2 	传送石6：63.79.0 	
	等待("500")
	循环(人物详细信息("35") != "233" && 人物详细信息("35") != "242")
		如果(人物详细信息("35") + 人物详细信息("36") != "311" && 人物详细信息("35") + 人物详细信息("36") != "342" && 人物详细信息("35") + 人物详细信息("36") != "292" && 人物详细信息("35") + 人物详细信息("36") != "289" && 人物详细信息("35") + 人物详细信息("36") != "195" && 人物详细信息("35") + 人物详细信息("36") != "142")
			登出回城()
			等待("1000")
		如果尾()
		//如果人在传送石3	
		如果(人物详细信息("35") == "162" && 人物详细信息("36") == "130")
			人物转身("2")
			等待("1000")
		如果尾()
		//如果人在传送石4	
		如果(人物详细信息("35") == "141" && 人物详细信息("36") == "148")
			人物转身("0")
		如果尾()
		//如果人在传送石5	
		如果(人物详细信息("35") == "72" && 人物详细信息("36") == "123")
			人物转身("2")
			等待("1000")
		如果尾()
		//如果人在传送石6	
		如果(人物详细信息("35") == "63" && 人物详细信息("36") == "79")
			人物转身("0")
			等待("1000")
		如果尾()
	循环尾()
	等待("1000")
模块结束()


//1.02-到西边传送石
///////////////////////////////////////////////////////////////////
脚本模块("到西边传送石")
//传送石1：233.78.0		传送石2：242.100.2 	传送石3：162.130.2
//传送石4：141.148.0 	传送石5：72.123.2 	传送石6：63.79.0 	
