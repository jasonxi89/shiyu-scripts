//	2.04-身上物品统计
///////////////////////////////////////////////////////////////////////////////	
脚本模块("身上物品统计")
	定义数组(#身上物品,"20")
	定义数组(#物品数量,"20")
	数组清值 (#身上物品)
	数组清值 (#物品数量)
	#物品计数器 = "9"
	循环(#物品计数器 < "30")
		如果(物品详细信息(#物品计数器,"1") != "" && 物品详细信息(#物品计数器,"1") != "时间水晶lv6")
			#数组计数器 = "1"
			循环(#数组计数器 <"20")
				如果(物品详细信息(#物品计数器,"1") == #身上物品.#数组计数器)
					#物品数量.#数组计数器 = #物品数量.#数组计数器 +"1"
					跳出循环()
				如果尾()
				如果(#身上物品.#数组计数器 == "")
					#身上物品.#数组计数器 = 物品详细信息(#物品计数器,"1")
					#物品数量.#数组计数器 = #物品数量.#数组计数器 +"1"
					跳出循环()
				如果尾()
				#数组计数器 = #数组计数器 + "1"
			循环尾()
		如果尾()
		#物品计数器 = #物品计数器 + "1" 
	循环尾()
	#物品总清单 = ""
	#计数器 = "1"
	循环(#计数器 <"20")
		如果(#身上物品.#计数器 != "")
			#物品总清单 = 相连(#物品总清单,#身上物品.#计数器)
			#物品总清单 = 相连(#物品总清单,"|")
			#物品总清单 = 相连(#物品总清单,#物品数量.#计数器)
			#物品总清单 = 相连(#物品总清单,"|")
		如果尾()
		#计数器 = #计数器 + "1"
	循环尾()
	#物品总清单 = 取文本左边(#物品总清单,取文本长度(#物品总清单) - "1")
	返回(#物品总清单)	
模块结束()
